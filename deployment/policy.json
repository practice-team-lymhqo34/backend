{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowBackendOnly",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::ACCOUNT_ID:role/backend-role"
      },
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::logiflow-storage/*",
        "arn:aws:s3:::logiflow-storage"
      ]
    }
  ]
}
